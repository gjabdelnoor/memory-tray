#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIDFILE="${SCRIPT_DIR}/memory-tray.pid"
APP_NAME="memory-tray"
AUTOSTART_DIR="${HOME}/.config/autostart"
DESKTOP_FILE="${AUTOSTART_DIR}/${APP_NAME}.desktop"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

is_running() {
    if [[ -f "$PIDFILE" ]]; then
        local pid
        pid="$(cat "$PIDFILE")"
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    # fallback: search by process name
    if pgrep -f "python3 ${SCRIPT_DIR}/memory_tray.py" >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

get_pid() {
    if [[ -f "$PIDFILE" ]]; then
        cat "$PIDFILE"
    else
        pgrep -f "python3 ${SCRIPT_DIR}/memory_tray.py" || true
    fi
}

status() {
    if is_running; then
        local pid
        pid="$(get_pid)"
        echo "memory-tray is running (pid $pid)"
    else
        echo "memory-tray is not running"
    fi
}

start_app() {
    if is_running; then
        echo "memory-tray is already running"
        return 0
    fi
    # Use setsid to fully detach from terminal
    setsid python3 "${SCRIPT_DIR}/memory_tray.py" >/dev/null 2>&1 &
    local pid=$!
    echo "$pid" > "$PIDFILE"
    echo "memory-tray started (pid $pid)"
}

stop_app() {
    local pid
    pid="$(get_pid)"
    if [[ -z "$pid" ]]; then
        echo "memory-tray is not running"
        return 0
    fi
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null || true
        # wait a bit for graceful exit
        local count=0
        while kill -0 "$pid" 2>/dev/null && [[ $count -lt 10 ]]; do
            sleep 0.2
            ((count++)) || true
        done
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null || true
        fi
        echo "memory-tray stopped"
    else
        echo "memory-tray is not running"
    fi
    rm -f "$PIDFILE"
}

kill_app() {
    local pids
    pids="$(pgrep -f "python3 ${SCRIPT_DIR}/memory_tray.py" || true)"
    if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
        echo "memory-tray killed"
    else
        echo "memory-tray is not running"
    fi
    rm -f "$PIDFILE"
}

autoon() {
    mkdir -p "$AUTOSTART_DIR"
    cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Type=Application
Name=Memory Tray
Exec=${SCRIPT_DIR}/run.sh
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
EOF
    chmod +x "$DESKTOP_FILE"
    echo "autostart enabled"
}

autooff() {
    if [[ -f "$DESKTOP_FILE" ]]; then
        rm -f "$DESKTOP_FILE"
        echo "autostart disabled"
    else
        echo "autostart was not enabled"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

case "${1:-status}" in
    on)
        start_app
        ;;
    off)
        stop_app
        ;;
    kill)
        kill_app
        ;;
    autoon)
        autoon
        ;;
    autooff)
        autooff
        ;;
    status|""|*)
        status
        ;;
esac
